# Website Environment Configuration
# Copy to /etc/website/website.env on production server

# Server Configuration
SERVER_PORT=8080
SERVER_ENV=production
FRONTEND_URL=https://yourwebsite.com

# Database
DATABASE_DSN=postgres://user:pass@localhost:5432/website?sslmode=disable
DATABASE_MAX_CONNECTIONS=20

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Authentication
JWT_SECRET=your-secret-key-here
SESSION_EXPIRY_HOURS=24

# Discord OAuth
DISCORD_CLIENT_ID=your-client-id
DISCORD_CLIENT_SECRET=your-client-secret
DISCORD_REDIRECT_URI=https://yourwebsite.com/auth/callback
DISCORD_SCOPES=identify,guilds
DISCORD_GUILD_ID=your-guild-id

# Roles
ADMIN_ROLE_ID=your-admin-role-id
MODERATOR_ROLE_ID=your-moderator-role-id

# Logging
LOG_LEVEL=info
LOG_CLI=false
