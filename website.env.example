# Website Environment Configuration
# Copy to /etc/website/website.env on production server
# For local Docker Compose, copy to ./website.env

# Server Configuration
SERVER_PORT=8080
SERVER_ENV=production
FRONTEND_URL=https://yourwebsite.com

# Frontend Build (optional)
# Used by Vite when building the web app.
# Leave empty to use same-origin requests.
VITE_API_BASE_URL=
VITE_WS_BASE_URL=

# Database
DATABASE_DSN=postgres://user:pass@localhost:5432/website?sslmode=disable
DATABASE_MAX_CONNECTIONS=20

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Authentication
JWT_SECRET=your-secret-key-here
SESSION_EXPIRY_HOURS=24

# Discord OAuth
DISCORD_CLIENT_ID=your-client-id
DISCORD_CLIENT_SECRET=your-client-secret
DISCORD_REDIRECT_URI=https://yourwebsite.com/auth/callback
DISCORD_SCOPES=identify,guilds,guilds.members.read
DISCORD_GUILD_ID=your-guild-id

# Roles
ADMIN_ROLE_ID=your-admin-role-id
MODERATOR_ROLE_ID=your-moderator-role-id

# Logging
LOG_LEVEL=info
LOG_HUMAN=false

# Updater (optional)
# Shared with website-updater.service when loaded from /etc/website/website.env
# REPO_OWNER=Sol-Armada
# REPO_NAME=website
# ARCH=amd64
# SERVICE_NAME=website
# INSTALL_PATH=/opt/website
# RELEASES_DIR=/opt/website-releases
# STATE_DIR=/var/lib/website
